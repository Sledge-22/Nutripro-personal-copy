# NutriPro local configuration
PORT=4173
APP_ENV=development
APP_NAME=NutriPro

# Mock mode stays enabled until real services are connected.
USE_MOCK_DATA=true

# Future database connection values.
DATABASE_URL=
DATABASE_PROVIDER=postgres

# Future auth/payment/email integrations.
SESSION_SECRET=replace-with-a-secure-secret
PAYMENT_PROVIDER=stripe
PAYMENT_SECRET_KEY=
EMAIL_PROVIDER=
EMAIL_FROM=support@nutripro.example
